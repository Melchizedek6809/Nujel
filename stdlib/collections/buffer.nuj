;;; Some functions dealing with buffers

(defn buffer/equal? (a b)
      (def len (:length a))
      (when-not (= len (:length b))
                (return #f))
      (dotimes (i len #t)
        (when-not (= (ref a i)
                     (ref b i))
                  (return #f))))
